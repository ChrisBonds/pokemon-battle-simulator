ax.plot(turns_ax, hp_s, color=PALETTE["setup_sweep"], label="Steven", lw=2)
ax.set_xlabel("Turn")
ax.set_ylabel("Team HP Fraction")
ax.set_title("HP Timeline - Greedy vs Setup Sweep (seed=42)")
ax.legend(frameon=False)
ax.set_ylim(0, 1.05)
plt.tight_layout()
plt.show()
print(f"Winner: {res.winner.name} after {res.turns} turns")
