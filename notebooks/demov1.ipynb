## 5. Small Interactive Experiment

Run a live **quick mini-tournament**. Adjust `MINI_POP`, `MINI_GENS`, and `BATTLES` to explore.
# Parameters
MINI_POP   = 20   # population size
MINI_GENS  = 10   # number of generations
BATTLES    = 3    # battles per pair per generation
MINI_SEED  = 7

from scripts.evolve import run_generation, reproduce, strategy_frequencies

rng_mini = random.Random(MINI_SEED)
random.seed(MINI_SEED)

# Equal initial population
per_strat  = MINI_POP // len(STRATEGIES)
strategies = []
for s in STRATEGIES:
    strategies.extend([s] * per_strat)
while len(strategies) < MINI_POP:
    strategies.append(rng_mini.choice(STRATEGIES))
rng_mini.shuffle(strategies)

mini_history = [strategy_frequencies(strategies)]

for g in range(1, MINI_GENS + 1):
    win_rates, _ = run_generation(strategies, roster, BATTLES, "random", rng_mini)
    strategies   = reproduce(strategies, win_rates, 0.05, rng_mini)
    mini_history.append(strategy_frequencies(strategies))

# Plot
fig, ax = plt.subplots(figsize=(8, 3.5))
for s in STRATEGIES:
    ax.plot([h.get(s, 0) for h in mini_history], label=s, color=PALETTE[s], lw=2)
ax.set_xlabel("Generation")
ax.set_ylabel("Frequency")
ax.set_title(f"Mini-Tournament: pop={MINI_POP}, gens={MINI_GENS}, seed={MINI_SEED}")
ax.legend(frameon=False, fontsize=9)
ax.spines[["top", "right"]].set_visible(False)
plt.tight_layout()
plt.show()
