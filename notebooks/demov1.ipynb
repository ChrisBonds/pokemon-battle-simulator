### 2b. HP Timeline

We replay the same seeds with a light logging wrapper to track total team HP across turns.
def hp_timeline(log_lines, t1_name, t2_name):
    """Extract per-turn HP snapshots from the battle log.
    
    Looks for lines like 'Turn N' and '  <pokemon> has N HP'.
    Falls back to a coarse proxy if the log format differs.
    """
    import re
    turns, hp1s, hp2s = [], [], []
    cur_turn, cur_hp1, cur_hp2 = 0, None, None

    turn_re = re.compile(r"--- Turn (\d+)")
    hp_re   = re.compile(r"(\S+) (?:has )?(\d+)/(\d+) HP")

    for line in log_lines:
        m = turn_re.search(line)
        if m:
            if cur_hp1 is not None:
                turns.append(cur_turn)
                hp1s.append(cur_hp1)
                hp2s.append(cur_hp2)
            cur_turn = int(m.group(1))
            cur_hp1 = cur_hp2 = None
    return turns, hp1s, hp2s


# Record HP at each turn during a fresh battle
class TrackedBattle(Battle):
    """Subclass that snapshots team HP after every turn."""
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.hp_trace = []

    def _run_turn(self) -> None:
        super()._run_turn()
        hp1 = sum(p.current_hp for p in self.t1.team) / max(1, sum(p.hp for p in self.t1.team))
        hp2 = sum(p.current_hp for p in self.t2.team) / max(1, sum(p.hp for p in self.t2.team))
        self.hp_trace.append((hp1, hp2))


rng2 = random.Random(42)
tg = Trainer("Gary", build_team(roster, archetype="offense", rng=rng2), strategy="greedy")
ts = Trainer("Steven", build_team(roster, archetype="offense", rng=rng2), strategy="setup_sweep")

tb = TrackedBattle(tg, ts, verbose=False)
res = tb.run()

turns_ax = list(range(1, len(tb.hp_trace) + 1))
hp_g = [x[0] for x in tb.hp_trace]
hp_s = [x[1] for x in tb.hp_trace]

